<div id="<%= dom_id checkin %>">
  <div class="card text-center" style="width: 18rem;">
      <div class="card-header">
          Attendance Register
      </div>
      <div class="card-body">
        <h5 class="card-title"><%= checkin.attendee.first_name %> <%= checkin.attendee.last_name %></h5>
        <p class="card-text"><%= checkin.attendee.email %></p>
      </div>
      <div class="card-footer text-body-secondary">
        <% if checkin.checked_in? == true %>Checked in on the <% end %><%= checkin.attendee.created_at %>
      </div>
  </div>   
  <%= link_to "Back", attendees_path %>
</div>
