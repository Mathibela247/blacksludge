<p style="color: green"><%= notice %></p>
<h1>Check-in</h1>
 <div class="row">
    <div class="col-md-4 col-xl-3 chat">
      <div class="card mb-sm-3 mb-md-0 contacts_card">
          <div class="card-header">
                <%= form_with(url: attendees_path, method: :get, data: { controller: "form-submission", turbo_frame: "attendees", turbo_action: "advance" }) do |form| %>
                  <div class="input-group">
                    <%= form.text_field :query, data: { action: "input->form-submission#search" }, class: "form-control search", placeholder: "Search attendee by First Name" %> 
                    <div class="input-group-prepend">
                      <span class="input-group-text search_btn"><i class="fas fa-search"></i></span>
                  </div>
                <% end %>
          </div> 
        </div> 
        <div class="card-body contacts_body">
          <turbo-frame id="attendees">
              <%= render "attendees", attendees: @attendees %>
          </turbo-frame>
        </div>
        <div class="card-footer"></div> 
      </div>
    </div>   
    <div class="col-md-8 col-xl-5 chat">
      <div class="card-body contacts_body">
        <div class="row justify-content-center">
          <div class="card" style="width: 36rem;">
          <%= render partial: "attendees/form", locals: { attendee: Attendee.new } %>
          </div>
        </div>
        </div>
    </div> 
    <!-- Rendering the checkin individuals -->
    <div class="col-md-8 col-xl-4 chat">
        <div class="card">
          <div class="card-header msg_head">
					  <div class="d-flex bd-highlight">
							<div class="img_cont">
								<img src="https://static.turbosquid.com/Preview/001292/481/WV/_D.jpg" class="rounded-circle user_img">
							  <span class="online_icon"></span>
							</div>
							<div class="user_info">
								<span>List of Check-ins</span>
								<p>All Attendees that checked in</p>
							</div>
						</div>
						<span id="action_menu_btn"><i class="fas fa-ellipsis-v"></i></span>
						<div class="action_menu">
							<ul>
									<li><i class="fas fa-user-circle"></i> View profile</li>
									<li><i class="fas fa-users"></i> Add to close friends</li>
									<li><i class="fas fa-plus"></i> Add to group</li>
									<li><i class="fas fa-ban"></i> Block</li>
							</ul>
						</div>
					</div>

          <div class="card-body msg_card_body">
							
                  <!-- Rendering the check-ins here -->
                  <turbo-frame id="checkins"> 
                      <%= render @checkins %>
                  </turbo-frame>    
        </div>
    </div>
  </div>
