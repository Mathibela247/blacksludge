<div class="container">
  <p style="color: green"><%= notice %></p>

  <h1 class="text-center pricing-table-title">Customers</h1>

  <div id="customers">
    <% @customers.each do |customer| %>
      <%= render customer %>
      <p>
        <%= link_to "Show this customer", customer %>
      </p>
    <% end %>
  </div>

  <%= link_to "New customer", new_customer_path %>
</div>