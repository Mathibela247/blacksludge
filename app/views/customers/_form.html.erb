<!-- Section: Design Block -->
<section class="background-radial-gradient overflow-hidden">
  <style>
    .background-radial-gradient {
      background-color: hsl(218, 41%, 15%);
      background-image: radial-gradient(650px circle at 0% 0%,
          hsl(218, 41%, 35%) 15%,
          hsl(218, 41%, 30%) 35%,
          hsl(218, 41%, 20%) 75%,
          hsl(218, 41%, 19%) 80%,
          transparent 100%),
        radial-gradient(1250px circle at 100% 100%,
          hsl(218, 41%, 45%) 15%,
          hsl(218, 41%, 30%) 35%,
          hsl(218, 41%, 20%) 75%,
          hsl(218, 41%, 19%) 80%,
          transparent 100%);
    }

    #radius-shape-1 {
      height: 220px;
      width: 220px;
      top: -60px;
      left: -130px;
      background: radial-gradient(#44006b, #ad1fff);
      overflow: hidden;
    }

    #radius-shape-2 {
      border-radius: 38% 62% 63% 37% / 70% 33% 67% 30%;
      bottom: -60px;
      right: -110px;
      width: 300px;
      height: 300px;
      background: radial-gradient(#44006b, #ad1fff);
      overflow: hidden;
    }

    .bg-glass {
      background-color: hsla(0, 0%, 100%, 0.9) !important;
      backdrop-filter: saturate(200%) blur(25px);
    }
  </style>

<div class="container px-4 py-5 px-md-5 text-center text-lg-start my-5">
  <div class="row gx-lg-5 align-items-center mb-5">
    <div class="col-lg-6 mb-5 mb-lg-0" style="z-index: 10">
        <h1 class="my-5 display-5 fw-bold ls-tight" style="color: hsl(218, 81%, 95%)">
          Open<br />
          <span style="color: hsl(218, 81%, 75%)">New Account</span>
        </h1>
          <div class="col-md-4">
          <div class="card pricing-card pricing-plan-basic">
            <div class="card-body">
              <i class="mdi mdi-cube-outline pricing-plan-icon"></i>
              <p class="pricing-plan-title"><%= @package.name %></p>
              <h3 class="pricing-plan-cost ml-auto">Price: R<%= @package.price %>/month</h3>
              <ul class="pricing-plan-features">
                <% @package.features.each do |feature| %>
                <li><%= feature %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
    </div>
    
    <div class="col-lg-6 mb-5 mb-lg-0 position-relative">
      <div class="card bg-glass">
        <div class="card-body px-4 py-5 px-md-5">
          
          <%= form_with(model: [@package, @customer]) do |form| %>
            <% if @customer.errors.any? %>
              <div style="color: red">
                <h2><%= pluralize(@customer.errors.count, "error") %> prohibited this customer from being saved:</h2>

                <ul>
                  <% @customer.errors.each do |error| %>
                    <li><%= error.full_message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>
            <div class="row">
              <h1 class="my-5 display-5 fw-bold ls-tight">Company Details</h1>
              <%# <%= form.text_field :package_id, value: @package.id %> 
              <div class="col-md-6 mb-4">
                <div class="form-outline mb-4">
                  <%= form.label "Company Name", style: "display: block" %>
                  <%= form.text_field :name, class: "form-control form-control-lg" %>
                </div>
              </div>
              <div class="col-md-6 mb-4">
                <div class="form-outline mb-4">
                  <%= form.label :customer_type_id, style: "display: block" %>
                  <%= form.select :customer_type_id, CustomerType.all.collect{ |p| [ p.name, p.id ] }, {include_blank: true}, class: "form-control form-control-lg" %>
                </div>
              </div>
              <div class="col-md-6 mb-4">
                <div class="form-outline mb-4">
                  <%= form.label :email, style: "display: block" %>
                  <%= form.text_field :email, class: "form-control form-control-lg" %>
                </div>
              </div>
            </div>
            <div class="row">
              <div class="col-md-6 mb-4">
                <div class="form-outline mb-4">
                  <%= form.label :landline, style: "display: block" %>
                  <%= form.text_field :landline, class: "form-control form-control-lg" %>
                </div>
              </div>
              <div class="col-md-6 mb-4">
                <div class="form-outline mb-4">
                  <%= form.label :mobile, style: "display: block" %>
                  <%= form.text_field :mobile, class: "form-control form-control-lg" %>
                </div>
              </div>
            </div>  
            <div class="row">
              <div class="col-md-6 mb-4">
                <div class="form-outline mb-4">
                  <%= form.label :industry_id, style: "display: block" %>
                  <%= form.select :industry_id, Industry.all.collect{ |p| [ p.name, p.id ] }, {include_blank: true}, class: "form-control form-control-lg" %>
                </div>
              </div>
              <div class="col-md-6 mb-4">
                <div class="form-outline mb-4">
                  <%= form.label :company_registration, style: "display: block" %>
                  <%= form.text_field :company_registration, class: "form-control form-control-lg" %>
                </div>
              </div>
            </div>
            <div class="row">
              <div class="col-md-6 mb-4">
                <div class="form-outline mb-4">
                  <%= form.label :vat_number, style: "display: block" %>
                  <%= form.text_field :vat_number, class: "form-control form-control-lg" %>
                </div>
              </div>
              <div class="col-md-6 mb-4">
                <div class="form-outline mb-4">
                  <%= form.label :main_contact, style: "display: block" %>
                  <%= form.text_field :main_contact, class: "form-control form-control-lg" %>
                </div>
              </div>
            </div>
            <div class="row">
              <div class="col-md-6 mb-4">
                <div class="form-outline mb-4">
                  <%= form.label "Special/Specific Platform Requirements", style: "display: block" %>
                  <%= form.text_field :platform_requirements, class: "form-control form-control-lg" %>
                </div>
              </div>
              <div class="col-md-6 mb-4">
                <div class="form-outline mb-4">
                  <%= form.label :person_responsible_for_payment, style: "display: block" %>
                  <%= form.text_field :person_responsible_for_payment, class: "form-control form-control-lg" %>
                </div>
              </div>  
            </div>
          <div class="form-outline mb-4">
            <%= form.submit class: "rounded-lg py-3 px-5 bg-blue-600 text-black inline-block font-medium cursor-pointer"  %>
          </div>
          <% end %>
        </div>  
      </div>
    </div>
  </div>
</div>
</section>