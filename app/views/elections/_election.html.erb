<div id="<%= dom_id election %>">
  <h5>
    <%= election.names %>
  </h5>
  <p>
  <strong>Description:</strong>
    <%= election.description%>
  </p>
  <p>
    <div id="candidates">
      <% @candidates = Candidate.where(:election_id => election.id) %>
      <% @candidates.each do |candidate| %>
        <%= render candidate %>
      <% end %>
    </div>
    <% if current_user.role.name == "Admin" %>
      <%= link_to "Add candidate", new_candidate_path(:election_id => election.id), class: "btn btn-info btn-sm" %>
    <% end %>
  </p>

</div>
