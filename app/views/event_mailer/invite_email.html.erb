
<h5 class="text-center pricing-table-subtitle"><%= @event.start_time %> to <%= @event.end_time %></h5>
<h1 class="text-center pricing-table-title"><strong><%= @event.event_name %></strong></h1>
<h5 class="text-center pricing-table-subtitle"><%= @event.location_name %></h5>
<h5 class="text-center pricing-table-subtitle"><%= @event.location_address %></h5>
<div class="row">
    <div class="col-md-4"> 
        <p>Hello, <%= @guest.fullname %>!</p>

        <p>You're invited to <%= @event.event_name %>! Please click the link below to update your details or confirm your attendance:</p>

        <p><%= link_to 'Update your details', @update_url, class: "btn btn-info" %></p>
    </div>  
</div>  
       
