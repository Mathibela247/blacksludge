<%= form_with(model: share) do |form| %>
  <% if share.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(share.errors.count, "error") %> prohibited this share from being saved:</h2>

      <ul>
        <% share.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :account_number, style: "display: block" %>
    <%= form.text_field :account_number %>
  </div>

  <div>
    <%= form.label :title, style: "display: block" %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :surname, style: "display: block" %>
    <%= form.text_field :surname %>
  </div>

  <div>
    <%= form.label :id_number, style: "display: block" %>
    <%= form.text_field :id_number %>
  </div>

  <div>
    <%= form.label :email, style: "display: block" %>
    <%= form.text_field :email %>
  </div>

  <div>
    <%= form.label :physical_address, style: "display: block" %>
    <%= form.text_area :physical_address %>
  </div>

  <div>
    <%= form.label "Type of Shares", style: "display: block" %>
    <%= form.select :type_of_shares_id, TypeOfShare.all.collect{ |p| [ p.name, p.id ] }, include_blank: true %>
  </div>

  <div>
    <%= form.label :share_volume, style: "display: block" %>
    <%= form.number_field :share_volume %>
  </div>

  <div>
    <%= form.label :custom, style: "display: block" %>
    <%= form.text_field :custom %>
  </div>

  <div>
    <%= form.label :notes, style: "display: block" %>
    <%= form.text_area :notes %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
