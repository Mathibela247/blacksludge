<%= form_with(model: resolution, id: "resolutions", data: { turbo_frame: "_top" }) do |form| %>
  <% if resolution.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(resolution.errors.count, "error") %> prohibited this resolution from being saved:</h2>

      <ul>
        <% resolution.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :description, style: "display: block" %>
    <%= form.text_area :description %>
  </div>
  <%= form.hidden_field :meeting_id %>
  <%= form.hidden_field :user_id, value: current_user.id %>
  <div>
    <%= form.label :open_voting, style: "display: block" %>
    <%= form.check_box :open_voting %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
